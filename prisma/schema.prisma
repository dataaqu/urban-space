generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id             String   @id @default(cuid())
  email          String   @unique
  hashedPassword String
  name           String?
  role           String   @default("admin")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SiteContent {
  id        String      @id @default(cuid())
  key       String
  section   String
  valueKa   String
  valueEn   String
  type      ContentType @default(TEXT)
  order     Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([section, key])
}

enum ContentType {
  TEXT
  RICH_TEXT
  IMAGE
}

model HeroSlide {
  id       String        @id @default(cuid())
  image    String
  videoUrl String?
  type     HeroSlideType @default(IMAGE)
  titleKa  String?
  titleEn  String?
  order    Int           @default(0)
  active   Boolean       @default(true)
}

enum HeroSlideType {
  IMAGE
  VIDEO
}

model Project {
  id            String          @id @default(cuid())
  slug          String          @unique
  titleKa       String
  titleEn       String
  descriptionKa String?
  descriptionEn String?
  category      ProjectCategory
  type          ProjectType
  images        String[]
  featured      Boolean         @default(false)
  featuredOrder Int?
  status        ProjectStatus   @default(COMPLETED)
  year          Int?
  location      String?
  area          Float?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

enum ProjectCategory {
  ARCHITECTURE
  URBAN
}

enum ProjectType {
  RESIDENTIAL_MULTI
  PUBLIC_MULTIFUNCTIONAL
  INDIVIDUAL_HOUSE
  URBAN_PLANNING
  COMPETITION
}

enum ProjectStatus {
  ONGOING
  COMPLETED
}

model TeamMember {
  id         String  @id @default(cuid())
  nameKa     String
  nameEn     String
  positionKa String
  positionEn String
  image      String?
  order      Int     @default(0)
}

model Partner {
  id      String  @id @default(cuid())
  name    String
  logo    String?
  website String?
  order   Int     @default(0)
}

model Service {
  id            String  @id @default(cuid())
  titleKa       String
  titleEn       String
  descriptionKa String?
  descriptionEn String?
  icon          String?
  order         Int     @default(0)
}

model ContactSubmission {
  id               String   @id @default(cuid())
  name             String
  email            String
  phone            String?
  message          String
  cadastralCode    String?
  buildingFunction String?
  area             Float?
  createdAt        DateTime @default(now())
  read             Boolean  @default(false)
}

model SiteSettings {
  id           String  @id @default(cuid())
  logo         String?
  favicon      String?
  address      String?
  email        String?
  phone        String?
  facebookUrl  String?
  instagramUrl String?
  linkedinUrl  String?
  mapLat       Float?
  mapLng       Float?
}
