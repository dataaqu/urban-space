generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id             String   @id @default(cuid())
  email          String   @unique
  hashedPassword String
  name           String?
  role           String   @default("admin")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SiteContent {
  id        String      @id @default(cuid())
  key       String
  section   String
  valueKa   String
  valueEn   String
  type      ContentType @default(TEXT)
  order     Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([section, key])
}

enum ContentType {
  TEXT
  RICH_TEXT
  IMAGE
}

model HeroSlide {
  id       String        @id @default(cuid())
  image    String
  videoUrl String?
  type     HeroSlideType @default(IMAGE)
  titleKa  String?
  titleEn  String?
  order    Int           @default(0)
  active   Boolean       @default(true)
}

enum HeroSlideType {
  IMAGE
  VIDEO
}

model Project {
  id            String          @id @default(cuid())
  slug          String          @unique
  titleKa       String
  titleEn       String
  category      ProjectCategory
  locationKa    String?
  locationEn    String?
  featuredImage String?
  featured      Boolean         @default(false)
  featuredOrder Int?
  pages         ProjectPage[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([category])
  @@index([featured])
}

model ProjectPage {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      PageType
  order     Int      @default(0)
  image1    String
  image2    String?
  textKa       String?
  textEn       String?
  textRightKa  String?
  textRightEn  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

enum PageType {
  SINGLE_IMAGE
  DOUBLE_IMAGE
}

enum ProjectCategory {
  ARCHITECTURE
  URBAN
}


model Service {
  id            String  @id @default(cuid())
  titleKa       String
  titleEn       String
  descriptionKa String?
  descriptionEn String?
  icon          String?
  order         Int     @default(0)
}

model ContactSubmission {
  id               String   @id @default(cuid())
  name             String
  email            String
  phone            String?
  message          String
  cadastralCode    String?
  buildingFunction String?
  area             Float?
  createdAt        DateTime @default(now())
  read             Boolean  @default(false)
}

